{
  "name": "luma-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "set EXPO_NO_TELEMETRY=1&& expo start",
    "android": "set EXPO_NO_TELEMETRY=1&& expo start --android",
    "ios": "set EXPO_NO_TELEMETRY=1&& expo start --ios",
    "web": "set EXPO_NO_TELEMETRY=1&& expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~55.0.0",
    "expo-audio": "~55.0.8",
    "expo-document-picker": "~55.0.13",
    "expo-status-bar": "~55.0.0",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.0",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "typescript": "~5.9.2"
  }
}
